<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>BE_Cruncher</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Images\app.ico</ApplicationIcon>
    <Title>Binary size reducer for Battery Emulator open source project.  Experimental.</Title>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Images\BE Cruncher.png" />
    <Resource Include="Images\logo-cropped.png" />
    <Resource Include="Images\app.ico" />
  </ItemGroup>

</Project>
