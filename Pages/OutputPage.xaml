<Page x:Class="BE_Cruncher.Pages.OutputPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Output"
      d:DesignWidth="720" d:DesignHeight="500">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" x:Name="HeaderText" Text="Step 4: Result" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="OpenOutputButton" Content="Open Output Folder" Width="160" Click="OpenOutputButton_Click"/>
            <Button x:Name="OpenLogsButton" Content="Open Logs Folder" Width="150" Margin="10,0,0,0" Click="OpenLogsButton_Click"/>
            <Button x:Name="BackToVersionsButton" Content="&#8592; Back to Versions" Width="150" Margin="10,0,0,0" Click="BackToVersionsButton_Click"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="SizeText" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="13"/>
                <TextBlock x:Name="DetailsText" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="Repair attempts" FontWeight="SemiBold" Margin="0,10,0,4"/>
                <TextBlock x:Name="RepairText" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="Warnings" FontWeight="SemiBold" Margin="0,10,0,4"/>
                <TextBlock x:Name="WarningsText" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
