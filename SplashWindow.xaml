<Window x:Class="BE_Cruncher.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BE Cruncher"
        Width="420" Height="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Icon="/Images/app.ico">
    <Border Background="White" BorderBrush="#DDDDDD"
            BorderThickness="1" CornerRadius="12">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- The full, uncropped logo has clean anti-aliased edges against its own white canvas —
                 use it here (rather than logo-cropped.png, whose edges were chroma-keyed for the dark
                 theme and would show a fringe against a white background) so there's no visible seam. -->
            <Image Grid.Row="0" Source="/Images/BE Cruncher.png" Stretch="Uniform" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,10,0,0">
                <TextBlock x:Name="StatusText" Text="Starting..." Foreground="#666666"
                           HorizontalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
